                                  "null"
                                ],
                                "description": "Spending budget for the API key, in cents"
                              },
                              "isOverBudget": {
                                "type": "boolean",
                                "description": "Whether the API key is currently over its budget"
                              }
                            }
                          }
                        }
                      }
                    },
                    {
                      "type": "object",
                      "properties": {
                        "apiKey": {
                          "type": "object",
                          "properties": {
                            "id": {
                              "type": "string",
                              "format": "uuid"
                            },
                            "name": {
                              "type": "string"
                            },
                            "rateLimit": {
                              "type": [
                                "integer",
                                "null"
                              ],
                              "description": "Rate limit in requests per second"
                            },
                            "budgetCents": {
                              "type": [
                                "integer",
                                "null"
                              ],
                              "description": "Spending budget for the API key, in cents"
                            },
                            "isOverBudget": {
                              "type": "boolean",
                              "description": "Whether the API key is currently over its budget"
                            },
                            "teamId": {
                              "type": "string",
                              "format": "uuid"
                            },
                            "createdAt": {
                              "type": "string",
                              "format": "date-time"
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
